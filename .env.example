# --- Supabase ---
# Public, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses RLS. NEVER expose to the browser or commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic ---
# Server-only. Used by the AI classify + draft-response server actions.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Overrides the model picked from app_settings.classifier_model.
# Default in app_settings: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Site ---
# Where invite/recovery emails should redirect users back to.
# Local: http://localhost:3000
# Prod:  https://restructure.chorusinsights.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
